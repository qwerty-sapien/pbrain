{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "252",
    "margin": 1
  },
  "paragraph": {
    "color": "252"
  },
  "heading": {
    "color": "230",
    "bold": true,
    "block_suffix": "\n"
  },
  "h1": {
    "prefix": "  ",
    "suffix": "  ",
    "color": "230",
    "background_color": "63",
    "bold": true,
    "margin": 2
  },
  "h2": {
    "prefix": "",
    "suffix": "",
    "color": "81",
    "bold": true,
    "underline": true,
    "margin": 2
  },
  "h3": {
    "prefix": "",
    "suffix": "",
    "color": "153",
    "bold": true,
    "margin": 1
  },
  "block_quote": {
    "color": "215",
    "indent": 2,
    "indent_token": "│ "
  },
  "list": {
    "color": "252",
    "level_indent": 4
  },
  "item": {
    "block_prefix": "  • ",
    "color": "252"
  },
  "enumeration": {
    "color": "252",
    "block_prefix": "  "
  },
  "text": {
    "color": "252"
  },
  "strong": {
    "color": "230",
    "bold": true
  },
  "emph": {
    "color": "153",
    "italic": true
  },
  "strikethrough": {
    "color": "244",
    "crossed_out": true
  },
  "link": {
    "color": "81",
    "underline": true
  },
  "link_text": {
    "color": "81",
    "bold": true,
    "underline": true
  },
  "code": {
    "color": "223",
    "background_color": "236",
    "prefix": " ",
    "suffix": " "
  },
  "code_block": {
    "color": "252",
    "background_color": "236",
    "margin": 2
  },
  "hr": {
    "color": "240",
    "block_prefix": "  ────────────────────────────────────────────────────────"
  }
